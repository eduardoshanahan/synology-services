# Bind loopback by default; expose via DSM reverse proxy.
SCHOLARSOME_HOST_BIND=127.0.0.1
SCHOLARSOME_HOST_PORT=3020

NODE_ENV=production
HTTP_PORT=3020
HOST=scholarsome.internal.example

# MySQL connection (shared nas-host-mysql on hhnas4).
# Database and user must be created manually before first deploy — see README.md.
DATABASE_URL=mysql://scholarsome:change-me-scholarsome-db-password@hhnas4.internal.example:3306/scholarsome

# Random string used to sign JWTs. Generate with: openssl rand -hex 32
JWT_SECRET=change-me-random-jwt-secret

# Redis (shared nas-host-redis on hhnas4).
REDIS_HOST=hhnas4.internal.example
REDIS_PORT=6379
REDIS_USERNAME=scholarsome
REDIS_PASSWORD=change-me-scholarsome-redis-password

# Storage: local saves files inside the container volume (scholarsome_media).
STORAGE_TYPE=local
STORAGE_LOCAL_DIR=/app/media

# SMTP (optional — required for password reset and registration confirmation emails).
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
