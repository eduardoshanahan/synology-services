# Public DNS name for clients:
#   dolt.internal.example
DOLT_BIND=0.0.0.0
DOLT_PORT=3307
# Optional: when set, deploy bootstrap also configures root@<host>.
# Keep unset unless you intentionally need remote root login.
# DOLT_ROOT_HOST=%
DOLT_ROOT_PASSWORD=change-me-strong-password

# Prometheus metrics endpoint.
DOLT_METRICS_BIND=0.0.0.0
DOLT_METRICS_PORT=11228

# Shared network used by internal database consumers.
SHARED_DB_NETWORK=hhlab-shared-db
