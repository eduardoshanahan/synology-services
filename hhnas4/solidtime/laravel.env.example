APP_NAME=solidtime
VITE_APP_NAME=solidtime
APP_ENV=production
APP_DEBUG=false
APP_URL=https://solidtime.internal.example
APP_FORCE_HTTPS=true
TRUSTED_PROXIES=0.0.0.0/0,2000:0:0:0:0:0:0:0/3

# Required. Generate these once before first real use:
#   docker compose run --rm scheduler php artisan self-host:generate-keys
APP_KEY=
PASSPORT_PRIVATE_KEY=
PASSPORT_PUBLIC_KEY=
SUPER_ADMINS=

LOG_CHANNEL=stderr_daily
LOG_LEVEL=info

DB_CONNECTION=pgsql
DB_HOST=postgres-shared
DB_PORT=5432
DB_SSLMODE=disable
DB_DATABASE=solidtime
DB_USERNAME=solidtime
DB_PASSWORD=change-me-db-password

MAIL_MAILER=smtp
MAIL_HOST=smtp-relay.internal.example
MAIL_PORT=2525
MAIL_ENCRYPTION=
MAIL_FROM_ADDRESS=no-reply@solidtime.internal.example
MAIL_FROM_NAME=solidtime
MAIL_USERNAME=
MAIL_PASSWORD=

QUEUE_CONNECTION=database

FILESYSTEM_DISK=local
PUBLIC_FILESYSTEM_DISK=public

GOTENBERG_URL=http://gotenberg:3000

APP_ENABLE_REGISTRATION=false
