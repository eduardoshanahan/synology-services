# App endpoint
PAPERLESS_HOST_BIND=127.0.0.1
PAPERLESS_HOST_PORT=8010
PAPERLESS_URL=https://paperless.internal.example
PAPERLESS_SECRET_KEY=change-me-long-random-secret

# App image/runtime
PAPERLESS_VERSION=2.20.10
PAPERLESS_TIME_ZONE=Europe/Dublin
PAPERLESS_OCR_LANGUAGE=eng
PAPERLESS_DOCKER_SUBNET=172.23.0.0/16
PAPERLESS_DNS=192.0.2.10

# Shared PostgreSQL on hhnas4
PAPERLESS_DBHOST=postgres.internal.example
PAPERLESS_DBPORT=5433
PAPERLESS_DBNAME=paperless
PAPERLESS_DBUSER=paperless
PAPERLESS_DBPASS=change-me-paperless-db-password

# Shared Redis on hhnas4
# Recommended: create a dedicated redis ACL user for paperless and use it here.
PAPERLESS_REDIS=redis://paperless:change-me-paperless-redis-password@redis.internal.example:6379

# Shared document extraction/conversion services
PAPERLESS_TIKA_ENABLED=1
PAPERLESS_TIKA_GOTENBERG_ENDPOINT=http://gotenberg.internal.example:3001
PAPERLESS_TIKA_ENDPOINT=http://tika.internal.example:9998
