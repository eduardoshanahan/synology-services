# Immich server bind/address on nas-host (keep loopback if using DSM reverse proxy)
IMMICH_HOST_BIND=127.0.0.1
IMMICH_HOST_PORT=2283

# Immich persistent library storage on NAS
UPLOAD_LOCATION=/volume1/docker/homelab/nas-host/immich/library

# Shared Postgres endpoint + credentials for Immich
DB_HOSTNAME=postgres.homelab.example
DB_PORT=5433
DB_USERNAME=immich
DB_PASSWORD=change-me
DB_DATABASE_NAME=immich

# Shared Redis endpoint + credentials for Immich
REDIS_HOSTNAME=redis.homelab.example
REDIS_PORT=6379
REDIS_USERNAME=immich
REDIS_PASSWORD=change-me

# Container runtime timezone
TZ=Europe/Dublin

# Immich image tag strategy (v2 tracks latest stable v2.x)
IMMICH_VERSION=v2
