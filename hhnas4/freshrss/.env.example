# Bind loopback by default; expose via DSM reverse proxy.
FRESHRSS_HOST_BIND=127.0.0.1
FRESHRSS_HOST_PORT=8095

# Container timezone and built-in refresh cron.
TZ=Europe/Dublin
CRON_MIN=13,43

# Trusted reverse proxy CIDRs for correct client IP handling.
TRUSTED_PROXY=127.0.0.1/32 172.16.0.1/12 192.0.2.10/16

# Public URL for this instance.
BASE_URL=https://freshrss.internal.example

# Shared PostgreSQL endpoint on nas-host.
DB_HOST=postgres.internal.example
DB_PORT=5433
DB_BASE=freshrss
DB_USER=freshrss
DB_PASSWORD=change-me-freshrss-db-password

# Optional first-run CLI bootstrap values.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-freshrss-admin-password
ADMIN_API_PASSWORD=change-me-freshrss-api-password

# Optional: uncomment to automate first-run install and admin creation.
# Only used on the very first run with an empty data volume.
# FRESHRSS_INSTALL=--default_user admin --base_url https://freshrss.internal.example --db-type pgsql --db-host postgres.internal.example:5433 --db-base freshrss --db-user freshrss --db-password change-me-freshrss-db-password --auth-type form --api-enabled
# FRESHRSS_USER=--user admin --email admin@example.com --password change-me-freshrss-admin-password --api-password change-me-freshrss-api-password
