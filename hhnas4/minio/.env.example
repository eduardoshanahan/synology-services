# Keep both MinIO listeners on loopback and publish them through the DSM
# reverse proxy using separate FQDNs.
MINIO_API_BIND=127.0.0.1
MINIO_API_PORT=9000
MINIO_CONSOLE_BIND=127.0.0.1
MINIO_CONSOLE_PORT=9001
MINIO_SERVER_URL=https://minio.example.internal
MINIO_BROWSER_REDIRECT_URL=https://minio-console.example.internal
MINIO_PROMETHEUS_AUTH_TYPE=public
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-now
