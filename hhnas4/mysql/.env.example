MYSQL_BIND=0.0.0.0
MYSQL_PORT=3306
MYSQL_TIMEZONE=UTC

# Set strong secrets on the NAS before first start.
MYSQL_ROOT_PASSWORD=change-me-root
MYSQL_DATABASE=ghost
MYSQL_USER=ghost
MYSQL_PASSWORD=change-me-ghost

# Conservative defaults for a small dedicated Ghost database.
MYSQL_INNODB_BUFFER_POOL_SIZE=256M
MYSQL_MAX_CONNECTIONS=80
