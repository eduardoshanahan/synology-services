OUTLINE_BIND=127.0.0.1
OUTLINE_PORT=3010

# Public URL used by Outline itself.
URL=https://outline.internal.example
PORT=3010

# Generate fresh values before first real use:
#   openssl rand -hex 32
SECRET_KEY=change-me-secret-key
UTILS_SECRET=change-me-utils-secret

DATABASE_URL=postgres://outline:change-me-db-password@postgres.internal.example:5433/outline
PGSSLMODE=disable
REDIS_URL=redis://:change-me-redis-password@redis.internal.example:6379

FILE_STORAGE=local
FILE_STORAGE_LOCAL_ROOT_DIR=/var/lib/outline/data
FORCE_HTTPS=true
DEFAULT_LANGUAGE=en_US
WEB_CONCURRENCY=1
LOG_LEVEL=info

# Outline requires at least one auth path for a usable sign-in flow.
# The current deployed setup uses SMTP magic-link auth, so leave OIDC empty
# unless you are explicitly adding OIDC later.
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_AUTH_URI=
OIDC_TOKEN_URI=
OIDC_USERINFO_URI=
OIDC_LOGOUT_URI=
OIDC_USERNAME_CLAIM=
OIDC_DISPLAY_NAME=
OIDC_SCOPES=

# SMTP magic-link auth and notifications.
# Use either SMTP_SERVICE or SMTP_HOST/SMTP_PORT, not both.
SMTP_SERVICE=
SMTP_HOST=smtp-relay.internal.example
SMTP_PORT=2525
SMTP_SECURE=false
SMTP_NAME=smtp-relay.internal.example
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=Outline <you@example.com>
