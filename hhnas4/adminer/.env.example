# Bind to the NAS LAN interface (change to 127.0.0.1 if a reverse proxy will
# handle HTTPS for you).
ADMINER_BIND=0.0.0.0
ADMINER_PORT=8070

# Select a design that works for operators, e.g. nette, cigarette, or fruity.
ADMINER_DESIGN=nette

# The shared-db network must match the other shared stacks.
SHARED_DB_NETWORK=hhlab-shared-db
