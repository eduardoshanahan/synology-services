TZ=UTC
WOODPECKER_AGENT_IMAGE=woodpeckerci/woodpecker-agent:latest
WOODPECKER_AGENT_CONTAINER_NAME=woodpecker-agent
WOODPECKER_SERVER=woodpecker.internal.example:9000
WOODPECKER_AGENT_SECRET=change-me
WOODPECKER_MAX_WORKFLOWS=1
WOODPECKER_HOSTNAME=nas-host
WOODPECKER_HEALTHCHECK_ADDR=127.0.0.1:3100
WOODPECKER_CA_CERT_HOST_PATH=/volume1/docker/homelab/nas-host/woodpecker-agent/certs/homelab-root-ca.crt
WOODPECKER_CA_BUNDLE_HOST_PATH=/volume1/docker/homelab/nas-host/woodpecker-agent/certs/ca-certificates-with-homelab.pem
# Leave blank unless you explicitly confirm a required Docker network.
WOODPECKER_BACKEND_DOCKER_NETWORK=
WOODPECKER_BACKEND_DOCKER_VOLUMES=/volume1/docker/homelab/nas-host/woodpecker-agent/certs/ca-certificates-with-homelab.pem:/etc/ssl/cert.pem:ro,/volume1/docker/homelab/nas-host/woodpecker-agent/certs/homelab-root-ca.crt:/etc/ssl/certs/homelab-root-ca.crt:ro
