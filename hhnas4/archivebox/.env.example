ARCHIVEBOX_BIND=0.0.0.0
ARCHIVEBOX_HOST_BIND=127.0.0.1
ARCHIVEBOX_PORT=8000
ARCHIVEBOX_TIMEZONE=UTC
ARCHIVEBOX_ALLOWED_HOSTS=archivebox.internal.example
CHROME_USER_DATA_DIR=/data/chrome-profile
# Optional: point this to an exported Netscape-format cookies file when you
# need ArchiveBox to replay consent/login state for difficult sites.
# COOKIES_FILE=/data/cookies.txt

# Keep the default ripgrep search backend when all data stays local on hhnas4.
# If you later move only /data/archive to remote storage, switch to:
# ARCHIVEBOX_SEARCH_BACKEND_ENGINE=sqlite
ARCHIVEBOX_SEARCH_BACKEND_ENGINE=ripgrep
