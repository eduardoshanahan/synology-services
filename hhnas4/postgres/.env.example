# Public DNS name for clients:
#   postgres.internal.example
POSTGRES_BIND=0.0.0.0
POSTGRES_PORT=5433
POSTGRES_LISTEN_ADDRESSES=*
SHARED_DB_NETWORK=hhlab-shared-db

# Bootstrap superuser for this PostgreSQL server.
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password
