GITEA_HTTP_BIND=0.0.0.0
GITEA_HTTP_PORT=3000
GITEA_SSH_BIND=0.0.0.0
GITEA_SSH_PORT=2222
GITEA_DATA_DIR=./data
GITEA_DB_TYPE=sqlite3
GITEA_DB_PATH=/data/gitea/gitea.db
GITEA_SECURITY_INSTALL_LOCK=true
GITEA_METRICS_ENABLED=true

GITEA_SERVER_PROTOCOL=http
GITEA_SERVER_DOMAIN=gitea.internal.example
GITEA_SERVER_ROOT_URL=https://gitea.internal.example/
GITEA_SERVER_SSH_DOMAIN=gitea.internal.example
GITEA_SERVER_SSH_PORT=2222
GITEA_SERVER_START_SSH_SERVER=false

# Container registry endpoint used by clients.
# Example image path after login/push:
#   gitea.internal.example/<owner>/<image>:<tag>
GITEA_REGISTRY_HOST=gitea.internal.example
GITEA_REGISTRY_EXTERNAL_URL=https://gitea.internal.example
GITEA_REGISTRY_INSECURE=false

GITEA_DISABLE_REGISTRATION=true

# SMTP mailer (recommended: internal relay on private-pi-02).
GITEA_MAILER_ENABLED=true
GITEA_SMTP_HOST=smtp-relay.internal.example
GITEA_SMTP_HOST_IP=192.0.2.10
GITEA_SMTP_PORT=2525
GITEA_SMTP_FROM=Gitea <noreply@internal.example>
GITEA_SMTP_USER=
GITEA_SMTP_PASSWORD=
GITEA_SMTP_PROTOCOL=smtp
